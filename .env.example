PORT=5000

# ── Supabase (Postgres) ── Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server-side only
SUPABASE_BUCKET=uploads                            # storage bucket for uploaded images

# ── CORS ── comma-separated; the deployed web app origin(s)
CLIENT_ORIGIN=http://localhost:5173

# ── Admin access ── (either list emails here, or set role='admin' in the users table)
ADMIN_EMAILS=wormy@wormyscantina.com
DISABLE_AUTH=false

# ── Email (SMTP) ──
EVENT_MANAGER_EMAIL=wormy@wormyscantina.com
CONTACT_RECIPIENT=                                 # optional; defaults to EVENT_MANAGER_EMAIL
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=wormy@wormyscantina.com
SMTP_PASS=replace-with-real-password
SMTP_FROM=wormy@wormyscantina.com
SMTP_FROM_NAME=Wormy (Wormy's Cantina)

# ── Firebase Admin (admin login verification) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Reminder cron (serverless) ──
# Set the same value in Vercel; the daily Vercel Cron job is sent with this bearer token.
CRON_SECRET=
