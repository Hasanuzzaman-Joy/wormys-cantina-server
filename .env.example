PORT=5000

# ── Supabase (Postgres) ── Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server-side only
SUPABASE_BUCKET=uploads                            # storage bucket for uploaded images

# ── CORS ── comma-separated web app origin(s). REQUIRED in production on Vercel.
# Include every URL visitors use (apex + www). Example:
# CLIENT_ORIGIN=https://wormyscantina.com,https://www.wormyscantina.com,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# ── Admin access ── (either list emails here, or set role='admin' in the users table)
ADMIN_EMAILS=wormy@wormyscantina.com
DISABLE_AUTH=false

# ── Email (Resend HTTP API — reliable on serverless) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx                 # resend.com → API Keys
EMAIL_FROM=wormy@wormyscantina.com                 # MUST be on a domain verified in Resend
EMAIL_FROM_NAME=Wormy (Wormy's Cantina)
EVENT_MANAGER_EMAIL=wormy@wormyscantina.com        # organizer notifications + default contact recipient
CONTACT_RECIPIENT=                                 # optional; defaults to EVENT_MANAGER_EMAIL

# ── Firebase Admin (admin login verification) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Reminder cron (serverless) ──
# Set the same value in Vercel; the daily Vercel Cron job is sent with this bearer token.
CRON_SECRET=
